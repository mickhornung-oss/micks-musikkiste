# Micks Musikkiste Configuration

# API
API_TITLE=Micks Musikkiste API
API_VERSION=1.0.1
APP_ENV=local
RELEASE_VERSION=1.0.1
RELEASE_SHA=local

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Logging
LOG_LEVEL=info
DEBUG=false

# Engine
ENGINE_MODE=mock
ENGINE_TYPE=mock
ENGINE_MOCK_DELAY=2
ENGINE_TIMEOUT=180
ACE_STEP_COMMAND=python ../scripts/ace_comfy_wrapper.py --workflow "C:/path/to/workflow.json" --comfy-url http://127.0.0.1:8188
