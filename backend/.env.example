# Micks Musikkiste - Konfiguration

# Engine-Modus
ENGINE_MODE=mock
# Moegliche Werte: mock, ace, musicgen

# Datenbank
# Fuer lokale Entwicklung ohne PostgreSQL (empfohlen):
DATABASE_URL=sqlite+aiosqlite:///./data/micks_musikkiste.db
# Alternative mit PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/musikkiste

# Engine-Konfiguration
ENGINE_MOCK_DELAY=2
ENGINE_REAL_COMMAND=
ENGINE_TIMEOUT=180
ACE_STEP_COMMAND=python ../scripts/ace_comfy_wrapper.py --workflow "C:/path/to/workflow.json" --comfy-url http://127.0.0.1:8188
ACE_STEP_MAX_DURATION=300
ENGINE_PROFILE=ace_turbo

# Logging
LOG_LEVEL=info
DEBUG=false

# Release metadata
APP_ENV=local
API_VERSION=2.0.0
RELEASE_VERSION=2.0.0
RELEASE_SHA=local

# Retry-Konfiguration
MAX_RETRIES=3
RETRY_DELAY=1.0

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
