# Micks Musikkiste - Konfiguration

# Engine-Modus
ENGINE_MODE=mock
# Mögliche Werte: mock, real, ace

# Datenbank
DATABASE_URL=postgresql+asyncpg://localhost:5432/micks_musikkiste
# Für lokale Entwicklung ohne PostgreSQL:
# DATABASE_URL=sqlite+aiosqlite:///./data/micks_musikkiste.db

# Engine-Konfiguration
ENGINE_MOCK_DELAY=2
ENGINE_REAL_COMMAND=
ENGINE_TIMEOUT=180
ACE_STEP_COMMAND=ace-step
ACE_STEP_MAX_DURATION=120

# Logging
LOG_LEVEL=info
DEBUG=false

# Release metadata
APP_ENV=local
API_VERSION=1.0.1
RELEASE_VERSION=1.0.1
RELEASE_SHA=local

# Retry-Konfiguration
MAX_RETRIES=3
RETRY_DELAY=1.0

# Server
HOST=127.0.0.1
PORT=8000
