{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "startCommand": "python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  },
  "env": {
    "RAILWAY_DOCKERFILE_PATH": "./Dockerfile",
    "ENGINE_MODE": "mock",
    "SERVER_HOST": "0.0.0.0",
    "LOG_LEVEL": "info",
    "DEBUG": "false"
  }
}
